<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Theme.Esp32" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/rc_accent_cyan</item>
        <item name="colorPrimaryVariant">@color/rc_accent_blue</item>
        <item name="colorOnPrimary">@color/rc_bg_deep</item>
        <item name="colorSecondary">@color/rc_accent_blue</item>
        <item name="colorSecondaryVariant">@color/rc_accent_blue_dim</item>
        <item name="colorOnSecondary">@color/rc_text_primary</item>
        <item name="android:colorBackground">@color/rc_bg_deep</item>
        <item name="colorSurface">@color/rc_bg_surface</item>
        <item name="colorOnSurface">@color/rc_text_primary</item>
        <item name="android:statusBarColor">@color/rc_bg_deep</item>
        <item name="android:navigationBarColor">@color/rc_bg_deep</item>
        <item name="android:windowBackground">@color/rc_bg_deep</item>

        <!-- Bottom sheet -->
        <item name="bottomSheetDialogTheme">@style/Theme.Esp32.BottomSheet</item>
    </style>

    <!-- Bottom Sheet style -->
    <style name="Theme.Esp32.BottomSheet" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorBackground">@color/rc_bg_surface</item>
        <item name="bottomSheetStyle">@style/Widget.Esp32.BottomSheet</item>
    </style>

    <style name="Widget.Esp32.BottomSheet" parent="Widget.MaterialComponents.BottomSheet">
        <item name="backgroundTint">@color/rc_bg_surface</item>
    </style>

    <!-- Fullscreen immersive -->
    <style name="Theme.Esp32.Immersive" parent="Theme.Esp32">
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Dark Alert Dialog -->
    <style name="AlertDialogDark" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="android:colorBackground">@color/rc_bg_card</item>
        <item name="android:textColorPrimary">@color/rc_text_primary</item>
        <item name="colorPrimary">@color/rc_accent_cyan</item>
    </style>

    <!-- Dark Popup Menu (for Device List ... button) -->
    <style name="DarkPopupMenuStyle" parent="Theme.MaterialComponents.DayNight">
        <item name="android:colorBackground">@color/rc_bg_card</item>
        <item name="android:textColorPrimary">@color/rc_text_primary</item>
        <item name="android:textColor">@color/rc_text_primary</item>
    </style>

</resources>
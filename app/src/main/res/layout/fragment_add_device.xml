<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet_rounded"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="@drawable/bg_sheet_handle"
        android:layout_gravity="center"
        android:layout_marginTop="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thêm Xe RC"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/rc_text_primary"
        android:paddingStart="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp" />

    <!-- Tab Row -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutAdd"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        app:tabSelectedTextColor="@color/rc_accent_cyan"
        app:tabTextColor="@color/rc_text_secondary"
        app:tabIndicatorColor="@color/rc_accent_cyan"
        app:tabBackground="@android:color/transparent"
        app:tabMode="fixed"
        app:tabGravity="fill" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/vpAddDevice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>

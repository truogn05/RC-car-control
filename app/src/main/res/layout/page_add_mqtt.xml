<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kết nối trực tiếp qua MQTT Broker"
            android:textSize="13sp"
            android:textColor="@color/rc_text_secondary"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tên Xe"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMqttName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/rc_text_primary"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="MQTT Broker URI"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMqttBroker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/rc_text_primary"
                android:text="tcp://broker.hivemq.com:1883" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="MQTT Topic điều khiển"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMqttTopic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/rc_text_primary"
                android:text="my_rc_car/control" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="URL Camera (tuỳ chọn)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="24dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMqttCamera"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/rc_text_primary"
                android:hint="http://192.168.x.x:81/stream" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMqttSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Lưu Xe"
            android:textColor="@color/rc_bg_deep"
            app:backgroundTint="@color/rc_accent_cyan" />

    </LinearLayout>
</ScrollView>

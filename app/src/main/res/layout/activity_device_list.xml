<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rc_bg_deep">

    <!-- Background gradient overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@drawable/bg_header_gradient" />

    <!-- Main content -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="48dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RC Control"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:textColor="@color/rc_text_primary"
                    android:letterSpacing="0.04" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chọn xe để bắt đầu lái"
                    android:textSize="14sp"
                    android:textColor="@color/rc_text_secondary"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/llEmptyState"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚗"
                    android:textSize="64sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chưa có xe nào"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/rc_text_primary"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhấn + để thêm xe RC của bạn"
                    android:textSize="14sp"
                    android:textColor="@color/rc_text_secondary"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Device list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDevices"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="88dp"
                android:clipToPadding="false"
                android:visibility="gone" />
        </LinearLayout>

        <!-- FAB -->
        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/fabAddDevice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="24dp"
            android:text="Thêm Xe"
            android:textColor="@color/rc_bg_deep"
            app:icon="@android:drawable/ic_input_add"
            app:iconTint="@color/rc_bg_deep"
            app:backgroundTint="@color/rc_accent_cyan"
            app:elevation="8dp" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</FrameLayout>

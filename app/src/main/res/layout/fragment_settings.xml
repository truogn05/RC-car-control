<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet_rounded"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="@drawable/bg_sheet_handle"
        android:layout_gravity="center"
        android:layout_marginTop="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cài Đặt"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/rc_text_primary"
        android:paddingStart="24dp"
        android:paddingTop="16dp" />

    <!-- Control Mode -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CHẾ ĐỘ ĐIỀU KHIỂN"
        android:textSize="11sp"
        android:textColor="@color/rc_text_secondary"
        android:letterSpacing="0.1"
        android:paddingStart="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Dùng Joystick"
            android:textSize="15sp"
            android:textColor="@color/rc_text_primary" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchJoystick"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:thumbTint="@color/rc_accent_cyan"
            app:trackTint="@color/rc_accent_cyan_dim" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/rc_divider" android:layout_marginTop="12dp" android:layout_marginBottom="4dp" />

    <!-- Sound Settings -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ÂM THANH"
        android:textSize="11sp"
        android:textColor="@color/rc_text_secondary"
        android:letterSpacing="0.1"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Âm thanh nút bấm"
            android:textSize="15sp"
            android:textColor="@color/rc_text_primary" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchSound"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            app:thumbTint="@color/rc_accent_cyan"
            app:trackTint="@color/rc_accent_cyan_dim" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/rc_divider" android:layout_marginTop="12dp" android:layout_marginBottom="4dp" />

    <!-- Connection info -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="KẾT NỐI"
        android:textSize="11sp"
        android:textColor="@color/rc_text_secondary"
        android:letterSpacing="0.1"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/tvSettingsBroker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="broker.hivemq.com"
        android:textSize="13sp"
        android:textColor="@color/rc_text_secondary"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/tvSettingsTopic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="my_rc_car/control"
        android:textSize="13sp"
        android:textColor="@color/rc_text_secondary"
        android:paddingStart="24dp"
        android:paddingEnd="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSettingsBack"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="← Về Danh Sách Xe"
        android:textColor="@color/rc_text_primary"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="20dp"
        app:backgroundTint="@color/rc_bg_card_elevated"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        app:strokeColor="@color/rc_divider" />
</LinearLayout>
